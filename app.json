{
  "expo": {
    "name": "Smart Market Bot",
    "slug": "Mobile_Robot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logocute.png",
    "scheme": "mobilerobot",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logocute.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F3FAF6",
        "foregroundImage": "./assets/images/logocute.png",
        "backgroundImage": "./assets/images/logocute.png",
        "monochromeImage": "./assets/images/logocute.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.truongduyyyy.mobilerobot"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logocute.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3FAF6",
          "android": {
            "image": "./assets/images/logocute.png",
            "imageWidth": 120
          }
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Cho phép Ứng dụng truy cập Microphone để nhận diện giọng nói."
        }
      ],
      "expo-image",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
